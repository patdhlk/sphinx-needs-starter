// Dev container for the Sphinx-Needs starter template.
// Pulls the prebuilt base image (Python 3.12 + uv + graphviz/plantuml/Java),
// fetches the ubc CLI on create, then runs `uv sync` to materialize the .venv
// from pyproject.toml / uv.lock.
//
// Prefer a fast pull over a local build. To customize the image instead,
// replace "image" with a "build" block pointing at the local Dockerfile.
{
    "name": "Sphinx-Needs Starter",
    "image": "ghcr.io/patdhlk/sphinx-needs-starter:latest",

    // ubc is useblocks' proprietary binary and is not redistributed in the
    // image; fetch it on create (needs root, hence sudo).
    "onCreateCommand": "sudo bash .devcontainer/install-ubc.sh",

    // Create the local .venv with the documentation toolchain.
    "postCreateCommand": "uv sync",

    "remoteUser": "vscode",

    // sphinx-autobuild serves a live HTML preview on port 8000.
    "forwardPorts": [8000],
    "portsAttributes": {
        "8000": {
            "label": "Sphinx live preview"
        }
    },

    "customizations": {
        "vscode": {
            "extensions": [
                "useblocks.ubcode",
                "ms-python.python",
                "swyddfa.esbonio",
                "tamasfe.even-better-toml",
                "trond-snekvik.simple-rst",
                // Diagram authoring (the build-time toolchain is in the Dockerfile):
                "jebbs.plantuml",
                "joaompinto.vscode-graphviz",
                "vstirbu.vscode-mermaid-preview"
            ],
            "settings": {
                // Point VS Code (and esbonio) at the uv-managed virtualenv.
                "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",

                // esbonio language server: use the project's Python and tell it
                // where the Sphinx conf.py lives (top-level source/).
                "esbonio.sphinx.pythonCommand": ["${workspaceFolder}/.venv/bin/python"],
                "esbonio.sphinx.confDir": "${workspaceFolder}/source",

                // Render PlantUML locally using the container's plantuml + JRE
                // (no external PlantUML server needed for live preview).
                "plantuml.render": "Local"
            }
        }
    }
}
